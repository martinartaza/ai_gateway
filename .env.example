# ── Database ──────────────────────────────────────────────────────────────────
# Docker:    mysql+pymysql://root:${MYSQL_ROOT_PASSWORD}@mysql/ai_gateway
# Local dev: mysql+pymysql://root:password@localhost/ai_gateway
DATABASE_URL=mysql+pymysql://root:changeme@mysql/ai_gateway
MYSQL_ROOT_PASSWORD=changeme

# ── LLM backend (Ollama) ──────────────────────────────────────────────────────
# Docker:    http://ollama:11434
# Local dev: http://localhost:11434
LLM_BASE_URL=http://ollama:11434
LLM_MODEL_NAME=qwen2.5:0.5b


# ── Rate limiting ─────────────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT=60/minute

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_RETENTION_DAYS=30

# ── Metrics endpoint (admin only) ────────────────────────────────────────────
METRICS_API_KEY=change-me-in-production
